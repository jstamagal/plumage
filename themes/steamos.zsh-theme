# ▸▸ plumage/steamos — combo meter
# tagline: deck blue, and your success streak is a combo counter
#
# Clean exits chain into a combo on the right. One failure and the
# counter is replaced by the single most honest word in gaming.

PROMPT='%F{39}▸▸%f %F{252}%n%F{240}·%F{39}${PLUMAGE_BOX}%f %F{240}[%F{250}%~%F{240}]%f %(?.%F{39}.%F{203})▸%f '
RPROMPT='%(?.%F{240}⟨combo %F{75}×${PLUMAGE_STREAK}%F{240}⟩%f.%F{240}⟨%F{203}wasted%F{240}⟩%f)'
